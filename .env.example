# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Database Configuration
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# JWT Configuration
JWT_SECRET=your-jwt-secret

# Django Configuration
SECRET_KEY=your-django-secret-key-change-this-in-production
DEBUG=True

# STRIDE Security: Allowed Hosts (comma-separated)
# In production, set to your domain: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# STRIDE Security: CORS Origins (comma-separated, production only)
# In production: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# STRIDE Spoofing Protection: reCAPTCHA Configuration
# Get keys from https://www.google.com/recaptcha/admin
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key

# STRIDE Repudiation Protection: External SIEM endpoint for audit logs (optional)
# Leave empty to disable external logging
AUDIT_LOG_SERVER=

# STRIDE Repudiation Protection: Enable immutable audit logging
AUDIT_LOG_IMMUTABLE=True

# Email Configuration (for password reset)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
